# Production data API. Auth and QR API bases are derived automatically.
API_BASE_URL=https://avatracker.online/api/v1

# Optional override for the mobile authentication API.
# MOBILE_API_BASE_URL=https://avatracker.online/api/mobile

# Local real-person test mode. Copy this file to .env.local and replace
# placeholders only on your workstation. Never commit .env.local.
TEST_IIN=<12-digit-test-iin>
TEST_BEARER_TOKEN=Bearer <test-token>
TEST_PHONE=+7<10-digit-number>
TEST_TODAY=2026-01-01

# Optional when the backend provides a separate refresh token.
# TEST_REFRESH_TOKEN=<refresh-token>
